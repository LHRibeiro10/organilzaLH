# Token do bot, obtido com o @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# IDs do Telegram dos organizadores autorizados, separados por vírgula
# (veja no README como descobrir seu user ID)
AUTHORIZED_USER_IDS=123456789,987654321

# Caminho para o arquivo JSON de credenciais da service account do Google Cloud
GOOGLE_CREDENTIALS_FILE=credentials.json

# Preencha GOOGLE_SHEET_ID (recomendado) OU GOOGLE_SHEET_NAME, não precisa dos dois
# O ID é o trecho da URL entre /d/ e /edit:
# https://docs.google.com/spreadsheets/d/ESSE_TRECHO_AQUI/edit
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=

# Nome exato da aba já existente com a estrutura de parcelas (coluna B = nome,
# colunas C..N = parcelas 1 a 12, coluna O = total)
SHEET_ABA_PAGAMENTOS=PARCELAS

# Linha onde começam os dados dos participantes nessa aba (cabeçalho mesclado
# ocupa as linhas 2-5, então os dados começam na linha 6)
LINHA_INICIAL=6

# Nome da aba de configuração (chave/valor). Se não existir, o bot cria
# automaticamente com "meta" = META_PADRAO na primeira execução
SHEET_ABA_CONFIG=Config
META_PADRAO=5500

# Valor a partir do qual o bot pede confirmação antes de gravar um pagamento
VALOR_CONFIRMACAO=500
